env_file_path = "../../../.env"

# Existing issued ACM certificate for huseyinbozkurt.dev / *.huseyinbozkurt.dev.
# Store the real ARN in your local terraform.tfvars.
acm_certificate_arn = "<issued-acm-certificate-arn>"

# Match the policy already attached to the live ALB listener unless intentionally changing it.
alb_https_ssl_policy = "<alb-https-ssl-policy-name>"

# Optional. Use when the production DATABASE_URL secret does not include sslmode.
# Leave null when DATABASE_URL already includes sslmode=require or when SSL is not required.
database_ssl_mode = null

# Keep public-site requests from hanging when the remote database is unavailable.
database_connect_timeout_seconds = 10

# Docker image path for the root global-bundle.pem CA bundle.
database_ssl_ca_file = "/app/global-bundle.pem"

# Download source used by the public-site container when database_ssl_ca_file is missing.
database_ssl_ca_url = "https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem"

# Cloudflare account ID that owns the Turnstile widget. Not a secret — safe to
# store in your local terraform.tfvars.
cloudflare_account_id = "<cloudflare-account-id>"

# Cloudflare Turnstile secret key — DO NOT set it here and DO NOT commit it.
# Provide it via the environment instead:
#   export TF_VAR_turnstile_secret_key="<turnstile-secret-key>"
# or as a secure CI/CD secret (TF_VAR_turnstile_secret_key). Provider auth uses a
# scoped CLOUDFLARE_API_TOKEN environment variable (also never committed).
# turnstile_secret_key = "set via TF_VAR_turnstile_secret_key, never here"
