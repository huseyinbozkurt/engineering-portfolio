# Local Docker PostgreSQL defaults. These are only for local development.
POSTGRES_DB="engineering_portfolio"
POSTGRES_USER="portfolio"
POSTGRES_PASSWORD="portfolio"
POSTGRES_PORT="5432"

# Local Docker connection string. In production, set DATABASE_URL in Secrets Manager
# to the remote PostgreSQL URL. Include sslmode=require in the URL when the remote
# database requires TLS, or set DATABASE_SSL_MODE below.
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/engineering_portfolio"
DATABASE_SSL_MODE="disable"
DATABASE_SSL_CA_FILE="global-bundle.pem"
DATABASE_SSL_CA_URL="https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem"
DATABASE_CONNECT_TIMEOUT_SECONDS="10"

# Local site URL. Production value: https://huseyinbozkurt.dev
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Production placeholders only; do not commit real remote DB credentials.
# DATABASE_URL="postgresql://<user>:<password>@<db-host>:5432/<database>?sslmode=require"
# DATABASE_SSL_MODE="require"
# DATABASE_SSL_CA_FILE="global-bundle.pem"
# DATABASE_SSL_CA_URL="https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem"
# DATABASE_CONNECT_TIMEOUT_SECONDS="10"

# Admin LLM configuration. Enable any built-in providers with a comma-separated list.
# Status checks use provider model/list endpoints by default and never expose keys in the UI.
LLM_PROVIDERS="openai,anthropic,deepseek"
LLM_STATUS_TIMEOUT_MS="3000"
LLM_ANALYSIS_TIMEOUT_MS="90000"
LLM_ANALYSIS_MAX_TOKENS="6000"

OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_STATUS_URL=""
OPENAI_MODEL="gpt-4o-mini"

ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_STATUS_URL=""
ANTHROPIC_API_VERSION="2023-06-01"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_STATUS_URL=""
DEEPSEEK_MODEL="deepseek-chat"

# Single custom or OpenAI-compatible LLM endpoint.
CUSTOM_LLM_NAME=""
CUSTOM_LLM_BASE_URL=""
CUSTOM_LLM_STATUS_URL=""
CUSTOM_LLM_API_KEY=""
CUSTOM_LLM_MODEL=""

# Optional: multiple custom providers. `apiKeyEnv` points to another env var.
# CUSTOM_LLM_CONNECTIONS='[{"id":"ollama","name":"Ollama","provider":"custom","baseUrl":"http://localhost:11434/v1","statusUrl":"http://localhost:11434/api/tags","model":"llama3.1"}]'
